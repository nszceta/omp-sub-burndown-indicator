{
  "name": "omp-sub-burndown-indicator",
  "version": "0.2.5",
  "description": "One-line subscription quota burndown indicator for Oh My Pi",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": "./src/index.ts",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "pack": "bun pm pack"
  },
  "omp": {
    "extensions": [
      "./src/index.ts"
    ],
    "settings": {
      "density": {
        "type": "enum",
        "description": "Pace signal density",
        "values": ["dense", "text"],
        "default": "dense"
      },
      "layout": {
        "type": "enum",
        "description": "Row layout: fit shrinks details to keep every subscription on one line; wrap keeps full details and moves whole segments to extra lines",
        "values": ["fit", "wrap"],
        "default": "fit"
      }
    }
  },
  "dependencies": {
    "@oh-my-pi/pi-ai": "^16.4.0",
    "@oh-my-pi/pi-tui": "^16.4.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "^16.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@oh-my-pi/pi-coding-agent": "^16.4.0",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  }
}
